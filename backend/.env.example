# =================================================================
# CATWEEK BACKEND CONFIGURATION
# =================================================================

# -----------------------------------------------------------------
# Environment Settings
# -----------------------------------------------------------------
# Options: dev, prod
ENV=dev

# Server binding (Defaults to 0.0.0.0:5000 in Docker)
PORT=5000
WORKERS=4

# -----------------------------------------------------------------
# Database Connectivity
# -----------------------------------------------------------------

# LOCAL: Used when ENV=dev
# Format: postgresql+psycopg://user:pass@host:port/db_name
# Note: Use 'db' if running in docker-compose, 'localhost' if running raw Python.
DATABASE_LOCAL=postgresql+psycopg://postgres:postgres@localhost:5432/catweek

# REMOTE: Used when ENV=prod (Neon / AWS / GCP)
# Pooled connection for general app usage (PgBouncer)
DATABASE_REMOTE=postgresql+psycopg://user:pass@ep-cool-darkness-123.us-east-2.aws.neon.tech/neondb?sslmode=require

# DIRECT: Required for migrations (Alembic) and test-db-conn CLI
# This MUST bypass the pooler (Port 5432)
DATABASE_REMOTE_DIRECT=postgresql+psycopg://user:pass@ep-cool-darkness-123-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------
# Database Connectivity
# -----------------------------------------------------------------
# API key — sent as header: X-Api-Key: <value>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=generate_a_secure_random_string_here

# --- WIP ---
# Secret key for JWT signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here