# Environment: dev | prod
ENV=dev

# Secret key for JWT signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Local database (used when ENV=dev)
DATABASE_LOCAL=postgresql://user:password@localhost:5432/db_name

# Remote database (used when ENV=prod)
DATABASE_REMOTE=postgresql://user:password@remote-host:5432/db_name

# API key — send as header: X-API-Key: <value>
API_KEY=your-api-key-here