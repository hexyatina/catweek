# Environment: dev | prod
ENV=dev

# --- only needed for ENV=prod ---

# API key — sent as header: X-Api-Key: <value>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here

# Remote database pooled
DATABASE_REMOTE=postgresql://user:password@pooler.neon.tech/neondb?sslmode=require

# Remote database direct (for migrations)
DATABASE_REMOTE_DIRECT=postgresql://user:password@direct.neon.tech/neondb?sslmode=require

# --- only needed for local dev without Docker ---
DATABASE_LOCAL=postgresql://postgres:postgres@localhost:5432/postgres

# --- WIP ---
# Secret key for JWT signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here